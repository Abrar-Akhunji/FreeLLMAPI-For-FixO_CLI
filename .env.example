# ============================================================
# REQUIRED — server
# ============================================================

# 64-char hex (32 bytes). Used to encrypt provider API keys at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: If you lose this key, every stored provider key becomes unrecoverable.
# IMPORTANT: Use a DIFFERENT key in production than in dev.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 3001)
PORT=3001

# Set to "production" on prod hosts. Enforces strict ENCRYPTION_KEY validation
# and disables verbose error responses.
NODE_ENV=development

# ============================================================
# REQUIRED — Firebase Admin (server-side)
# ============================================================

# Path to the Firebase service account JSON. In production, place this OUTSIDE
# the web root (e.g. /etc/secrets/firebase-admin.json) and reference by
# absolute path. Never commit this file or include it in deployment archives.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-admin.json

# ============================================================
# REQUIRED — Firebase Web SDK (client-side, baked into Vite bundle)
# ============================================================
# These are public by Firebase design (Auth restricts misuse by domain).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================
# OPTIONAL
# ============================================================

# Where the dashboard fetches API from (default: http://localhost:3001)
VITE_API_URL=http://localhost:3001

# Comma-separated extra browser origins allowed to call /api/*.
# localhost:5173, 127.0.0.1:5173, [::1]:5173 are allowed by default for the
# Vite dev dashboard. Set this when serving the dashboard from a different
# host than the API (e.g. a custom domain).
# DASHBOARD_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Logger verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Feature flags (read by env.ts, can also be set per-user via /api/settings)
SMART_ROUTING_ENABLED=true
PROMPT_TRANSLATION_ENABLED=true
MULTI_TENANT_AUTH_ENABLED=true

# Local Ollama integration (off by default)
OLLAMA_LOCAL_ENABLED=false
OLLAMA_LOCAL_URL=http://localhost:11434
