{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/_diag", "destination": "/api/_diag.mjs" },
    { "source": "/api/_cjs", "destination": "/api/_diag.cjs" },
    { "source": "/api/(.*)", "destination": "/api/index.mjs" },
    { "source": "/v1/(.*)", "destination": "/api/index.mjs" },
    { "source": "/((?!api/|v1/|assets/).*)", "destination": "/index.html" }
  ]
}
